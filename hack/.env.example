# ── Gemini AI (required) ──────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com
REACT_APP_GEMINI_API_KEY=your_gemini_api_key_here

# ── Neon Postgres (required for auth) ────────────────────────────────────────
# 1. Create a free database at https://neon.tech
# 2. Copy the connection string from the Neon dashboard
# 3. In Vercel: Settings → Environment Variables → add POSTGRES_URL
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require

# ── JWT (required for auth) ───────────────────────────────────────────────────
# Any random string — make it long and secret in production
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── Local dev only ────────────────────────────────────────────────────────────
# When running the old Express server locally, point the frontend at it.
# Leave unset in Vercel (defaults to relative /api).
# REACT_APP_API_URL=http://localhost:3001/api
